@prefix : <http://www.example.org/starwars#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/starwars#> .

<http://www.example.org/starwars> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/starwars#hasWeapon
:hasWeapon rdf:type owl:ObjectProperty ;
           rdfs:domain :Character ;
           rdfs:range :Weapon .


###  http://www.example.org/starwars#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Character ;
           rdfs:range :Place .


###  http://www.example.org/starwars#relativeOf
:relativeOf rdf:type owl:ObjectProperty ,
                     owl:SymmetricProperty ;
            rdfs:domain :Character ;
            rdfs:range :Character .


###  http://xmlns.com/foaf/0.1/name
foaf:name rdf:type owl:ObjectProperty ;
          rdfs:domain :Character ;
          rdfs:range :Name .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/starwars#Character
:Character rdf:type owl:Class ;
           owl:disjointWith :Place .


###  http://www.example.org/starwars#Droid
:Droid rdf:type owl:Class ;
       rdfs:subClassOf :Character .


###  http://www.example.org/starwars#Jedi
:Jedi rdf:type owl:Class ;
      rdfs:subClassOf :Character .


###  http://www.example.org/starwars#Lightsaber
:Lightsaber rdf:type owl:Class ;
            rdfs:subClassOf :Weapon .


###  http://www.example.org/starwars#Mandolorian
:Mandolorian rdf:type owl:Class ;
             rdfs:subClassOf :Character .


###  http://www.example.org/starwars#Sith
:Sith rdf:type owl:Class ;
      rdfs:subClassOf :Character .


###  http://www.example.org/starwars#Weapon
:Weapon rdf:type owl:Class .


###  http://www.example.org/starwars#Name
:Name rdf:type owl:Class .


###  http://www.example.org/starwars#Place
:Place rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/starwars#Han_Solo
:Han_Solo rdf:type owl:NamedIndividual ,
                   :Character .


###  http://www.example.org/starwars#LightsaberName
:LightsaberName rdf:type owl:NamedIndividual ,
                         :Name ;
                rdfs:label "Skywalker's Lightsaber" .


###  http://www.example.org/starwars#LukeLightsaber
:LukeLightsaber rdf:type owl:NamedIndividual ,
                         :Lightsaber ;
                foaf:name :LightsaberName .


###  http://www.example.org/starwars#LukeName
:LukeName rdf:type owl:NamedIndividual ,
                   :Name ;
          rdfs:label "Luke Skywalker" .


###  http://www.example.org/starwars#LukeSkywalker
:LukeSkywalker rdf:type owl:NamedIndividual ,
                        :Jedi ;
               :hasWeapon :LukeLightsaber ;
               :locatedIn :Tatooine ;
               foaf:name :LukeName ;
               rdfs:comment "A legendary Jedi Knight who fought in the Galactic Civil War." .


###  http://www.example.org/starwars#Obi-Wan_Kenobi
:Obi-Wan_Kenobi rdf:type owl:NamedIndividual ,
                         :Jedi .


###  http://www.example.org/starwars#Tatooine
:Tatooine rdf:type owl:NamedIndividual ,
                   :Place ;
          rdfs:comment "A desert planet in the Outer Rim." .


